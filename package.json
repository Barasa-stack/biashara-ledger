{
  "name": "biashara-ledger",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "electron:dev": "NODE_ENV=development electron electron/main.cjs",
    "electron:build": "npm run build && electron-builder build --mac --x64 --arm64",
    "dist:win": "electron-builder build --win --x64",
    "dist:mac": "electron-builder build --mac --x64 --arm64",
    "dist:mac-x64": "electron-builder build --mac --x64",
    "dist:mac-arm64": "electron-builder build --mac --arm64",
    "dist:linux": "electron-builder build --linux --x64",
    "dist:all": "npm run build && electron-builder build --win --x64 --mac --x64 --arm64 --linux --x64",
    "release:win": "npm run build && electron-builder build --win --x64 --publish=always",
    "release:mac": "npm run build && electron-builder build --mac --x64 --arm64 --publish=always",
    "release:linux": "npm run build && electron-builder build --linux --x64 --publish=always",
    "release:all": "npm run build && electron-builder build --win --x64 --mac --x64 --arm64 --linux --x64 --publish=always",
    "generate:license": "node scripts/generate-license.js",
    "test-email": "node scripts/test-email.js",
    "backup-db": "node scripts/backup-db.js",
    "check-env": "node scripts/check-env.js",
    "test-api": "node scripts/test-api.js",
    "verify": "node scripts/check-env.js && node scripts/test-api.js",
    "check-services": "node scripts/test-api.js",
    "migrate-data": "node --import tsx scripts/migrate-data.ts",
    "verify:tenant-isolation": "node --import tsx scripts/verify-tenant-isolation.ts",
    "build:webpack": "next build",
    "test:all": "node scripts/check-env.js && node scripts/test-api.js",
    "verify-deployment": "node scripts/verify-deployment.js",
    "postinstall": "node -e \"try{require('electron-rebuild')}catch(e){}\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@niledatabase/nextjs": "^5.3.1",
    "@niledatabase/server": "^5.3.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.3.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.400.0",
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^10.0.3",
    "electron": "^42.5.2",
    "electron-builder": "^26.15.3",
    "puppeteer": "^25.1.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.5",
    "typescript": "^5.7.0",
    "wait-on": "^9.0.10"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "allowScripts": {
    "better-sqlite3": true
  },
  "main": "electron/main.cjs",
  "author": "Biashara Ledger",
  "description": "Biashara Ledger - Offline Accounting Software",
  "overrides": {
    "next": "$next"
  }
}
